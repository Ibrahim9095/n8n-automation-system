      "id": "6c55a80d-5641-4d1d-bd66-71dbd0dfe933",
      "name": "DeepSeek Chat Model",
      "credentials": {
        "deepSeekApi": {
          "id": "ZOK5xwwi5YTx0zxL",
          "name": "DeepSeek account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// 1. Süni intellektdən gələn xam mətni götürürük\n// (Buradakı 'text' sözünü DeepSeek nodunun qaytardığı output dəyişəninə uyğun dəyişə bilərsiniz, adətən 'text' və ya 'message.content' olur)\nlet rawText = $input.item.json.text || $input.item.json.message?.content;\n\nif (!rawText) {\n    throw new Error(\"Süni intellektdən heç bir mətn gəlmədi!\");\n}\n\ntry {\n    // 2. Əgər Sİ mətni ```json ... ``` içində göndəribsə, lazımsız hissələri təmizləyirik\n    let cleanText = rawText\n        .replace(/```json/g, '')\n        .replace(/```/g, '')\n        .trim();\n\n    // 3. Mətni real JSON obyektinə çeviririk\n    let parsedData = JSON.parse(cleanText);\n\n    // 4. n8n-in növbəti nodlarda rahatlıqla tək-tək oxuya bilməsi üçün datanı ayırırıq\n    return {\n        json: {\n            sehirli_soz: parsedData.sehirli_soz,\n            instagram_caption: parsedData.instagram_caption,\n            tags: parsedData.tags,\n            unsplash_query: parsedData.unsplash_query\n        }\n    };\n\n} catch (error) {\n    // Əgər JSON formatında xəta olarsa, xətanı və xam mətni görmək üçün:\n    return {\n        json: {\n            error: \"JSON formatlama xətası baş verdi!\",\n            raw_response: rawText\n        }\n    };\n}"
      },
